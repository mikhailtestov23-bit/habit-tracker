# sqlite for local development without external services, supabase for Vercel.
DATA_BACKEND=sqlite

# Supabase project URL. On Vercel set this in Production and Preview.
NEXT_PUBLIC_SUPABASE_URL=

# Public browser-safe key. Supabase now recommends publishable keys.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy public key fallback, if your project still uses anon keys.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key for API routes. Prefer the new sb_secret_* key.
SUPABASE_SECRET_KEY=

# Legacy server-only fallback.
SUPABASE_SERVICE_ROLE_KEY=

# Optional extra protection for manually calling cron endpoints.
CRON_SECRET=
